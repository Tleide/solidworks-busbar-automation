# Visual Studio / C# build output
.vs/
bin/
obj/
*.user
*.suo
*.cache
*.pdb
*.exe
*.dll

# Keep manually collected SolidWorks interop DLLs for this learning project.
!C#/TopToDown/ReferenceDLL/*.dll
!C#/FeatureExtract/ReferenceDLL/*.dll

# SolidWorks temporary / backup files
~$*
*.bak
*.tmp
*.swp
*.sldprt~
*.sldasm~
*.slddrw~

# Generated busbar parts from API runs
SWtopToDown/Busbar_*.SLDPRT
SWtopToDown/Busbar_*.sldprt
!SWtopToDown/Busbar_Skeleton.SLDPRT
!SWtopToDown/Busbar_Skeleton.sldprt

# Demo media can be large; keep source/project history light.
demo/*.mp4

# OS files
Thumbs.db
Desktop.ini
.DS_Store
